{
  "name": "@reuters-graphics/graphics-atlas-topojson",
  "version": "0.1.0",
  "description": "TopoJSON country + disputed-border assets for @reuters-graphics/graphics-atlas-client — polygons & lines at three scales, built from reuters-graphics/country-borders (Overture Maps, ODbL).",
  "repository": "https://github.com/reuters-graphics/graphics-atlas-topojson",
  "license": "MIT",
  "private": false,
  "files": [
    "topojson/**/*"
  ],
  "scripts": {
    "build:maps": "node bin/buildMaps/index.js",
    "build:polygons": "node bin/buildMaps/buildPolygons.js",
    "build:lines": "node bin/buildMaps/buildLines.js",
    "prepublishOnly": "npm run build:maps"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@reuters-graphics/graphics-atlas-client": "^0.5.2",
    "@turf/bbox": "^7.2.0",
    "@turf/boolean-intersects": "^7.2.0",
    "@turf/helpers": "^7.2.0",
    "topojson-client": "^3.1.0",
    "topojson-server": "^3.0.1"
  }
}
